# Database connections
# Use PgBouncer port 6543 for DATABASE_URL with ?pgbouncer=true when deploying to serverless/Vercel
DATABASE_URL="postgresql://username:password@hostname:6543/database?pgbouncer=true&connection_limit=2"
DATABASE_POOL_MAX=2
DIRECT_URL="postgresql://username:password@hostname:5432/database"

# Supabase configuration
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Authentication (NextAuth)
NEXTAUTH_SECRET="your-nextauth-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# Upstash Redis serverless cache credentials (TTL-based map fallback used if missing)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Background tasks & Cron security (required in production)
CRON_SECRET="your-cron-secret-key-for-scheduler"

# Database Seeding credentials (optional, fallback values used if not set)
SEED_ADMIN_EMAIL="admin@atomquest.com"
SEED_ADMIN_PASSWORD="your-admin-seed-password-here"
SEED_ADMIN_NAME="Demo Admin"

SEED_MANAGER_EMAIL="manager@atomquest.com"
SEED_MANAGER_PASSWORD="your-manager-seed-password-here"
SEED_MANAGER_NAME="Demo Manager"

SEED_EMPLOYEE_EMAIL="employee@atomquest.com"
SEED_EMPLOYEE_PASSWORD="your-employee-seed-password-here"
SEED_EMPLOYEE_NAME="Demo Employee"
